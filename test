local function SmartEquipRemote(requiredUnitName)
    local inv, equippedUids, _ = ScanRAMInventory()
    local targetUid = nil
    local isAlreadyEquipped = false

    if requiredUnitName == "Rafflesia" and inv.hasRaff then
        targetUid = inv.raffUid; isAlreadyEquipped = inv.raffEquipped
    elseif requiredUnitName == "Lawnmower" and inv.hasLawn then
        targetUid = inv.lawnUid; isAlreadyEquipped = inv.lawnEquipped
    elseif requiredUnitName == "Tomato" and inv.hasTomato then
        targetUid = inv.tomatoUid; isAlreadyEquipped = inv.tomatoEquipped
    end

    if not targetUid then
        DebugLog("❌ [EQUIP] ไม่มี " .. requiredUnitName .. " ในกระเป๋า!")
        return false
    end

    if isAlreadyEquipped then
        DebugLog("✅ [EQUIP] " .. requiredUnitName .. " ถูกใส่อยู่แล้ว! (ข้ามการสวมใส่)")
        return true
    end

    local rf = ReplicatedStorage:WaitForChild("RemoteFunctions", 3)
    if not rf or not rf:FindFirstChild("SetUnitEquipped") then return false end

    if #equippedUids >= 5 then
        DebugLog("🧹 [EQUIP] ช่องใส่เต็ม! ถอดไอเทมชิ้นแรกออก: " .. tostring(equippedUids[1]))
        pcall(function() rf.SetUnitEquipped:InvokeServer(equippedUids[1], false) end)
        task.wait(0.5)
    end

    DebugLog("🔄 [EQUIP] ยิง Remote สวมใส่ " .. requiredUnitName .. " [" .. targetUid .. "]")
    local success = pcall(function() rf.SetUnitEquipped:InvokeServer(targetUid, true) end)
    task.wait(1.5)
    return success
end

