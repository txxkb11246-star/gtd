            local conn; conn = baseHP.Changed:Connect(function(val)
                if val <= 0 then isEnd.value = true; conn:Disconnect() end
            end)
        end)
    end

    local function safeWait(seconds)
        DebugLog("⏳ Waiting for " .. tostring(seconds) .. " seconds...")
        local start = tick()
        while tick() - start < seconds do
            if isEnd.value then return false end
            task.wait(0.2)
        end
        return true
    end

    local function deployLawnmower(pathIndex, config, lawName)
        if isEnd.value then return end
        
        local offset = 1.5
        local randomX = (math.random() * (offset * 2)) - offset
        local randomZ = (math.random() * (offset * 2)) - offset

        local finalPos = Vector3.new(config.pos.X + randomX, config.pos.Y, config.pos.Z + randomZ)
        local finalCF = CFrame.new(finalPos) * (config.cf - config.cf.Position)
        
