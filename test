local function SafeNum(input)
    if type(input) == "number" then return math.floor(input) end
    local s = tostring(input):upper():gsub(",", "")
    local nStr = s:match("[%d%.]+")
    local val = tonumber(nStr) or 0
    if s:find("K") then val = val * 1000 elseif s:find("M") then val = val * 1000000 end
    return math.floor(val)
end

