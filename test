local function SafeNum(input)
    if type(input) == "number" then return math.floor(input) end
    local s = tostring(input):upper():gsub(",", "")
    local nStr = s:match("[%d%.]+")
    local val = tonumber(nStr) or 0
    if s:find("K") then val = val * 1000 elseif s:find("M") then val = val * 1000000 end
    return math.floor(val)
end

local function GetSafeCurrency(ctype)
    local val = 0
    local retries = 0
    while retries < 15 do
        pcall(function()
            local lbl
            if ctype == "gems" then
                lbl = player.PlayerGui:FindFirstChild("SpaceGemsDisplay", true) or player.PlayerGui.GameGui.Screen.Bottom.CurrencyDisplay:FindFirstChild("SpaceGemsDisplay")
            else
                lbl = player.PlayerGui:FindFirstChild("SeedsDisplay", true) or player.PlayerGui.GameGui.Screen.Bottom.CurrencyDisplay:FindFirstChild("SeedsDisplay")
            end
            local textValue = lbl and lbl:FindFirstChild("Title") and lbl.Title.Text or ""
            val = SafeNum(textValue)
        end)
        if val == 250 or val == 0 then
            retries = retries + 1
            task.wait(1)
        else
            break 
        end
    end
    return val
end

