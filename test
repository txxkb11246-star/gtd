        task.spawn(function()
            local baseHP = Workspace:WaitForChild("Map", 60):WaitForChild("BaseHP", 60)
            if not baseHP then return end
            local conn; conn = baseHP.Changed:Connect(function(val)
                if val <= 0 then isEnd.value = true; conn:Disconnect() end
            end)
        end)
    end

    local function safeWait(seconds)
        DebugLog("⏳ Waiting for " .. tostring(seconds) .. " seconds...")
        local start = tick()
        while tick() - start < seconds do
            if isEnd.value then return false end
            task.wait(0.2)
        end
        return true
    end

    local function deployLawnmower(pathIndex, config, lawName)
        if isEnd.value then return end
        
        local offset = 1.5
        local randomX = (math.random() * (offset * 2)) - offset
        local randomZ = (math.random() * (offset * 2)) - offset

        local finalPos = Vector3.new(config.pos.X + randomX, config.pos.Y, config.pos.Z + randomZ)
        local finalCF = CFrame.new(finalPos) * (config.cf - config.cf.Position)
        
        local unitID = "unique_1"
        if farmUnit == "Rafflesia" then unitID = "unit_rafflesia" elseif farmUnit == "Lawnmower" then unitID = "unit_lawnmower" end

        DebugLog("🚀 Attempting to place " .. tostring(lawName) .. " at PathIndex: " .. tostring(pathIndex))

        for i = 1, 3 do
            if isEnd.value then return end
            local ok, result = pcall(function() 
                return rf.PlaceUnit:InvokeServer(unitID, {Valid = true, PathIndex = pathIndex, Position = finalPos, DistanceAlongPath = config.dist, CF = finalCF, Rotation = 180}) 
            end)

            if ok then 
                DebugLog("✅ SUCCESS: " .. tostring(lawName) .. " placed on attempt " .. tostring(i))
                break 
            else
                DebugLog("❌ ERROR: Failed to place " .. tostring(lawName) .. " on attempt " .. tostring(i) .. " | Error: " .. tostring(result))
