local function GetCurrentCurrency(ctype)
    local val = 0
    pcall(function()
        local lbl
        if ctype == "gems" then
            lbl = player.PlayerGui:FindFirstChild("SpaceGemsDisplay", true)
            if not lbl then lbl = player.PlayerGui.GameGui.Screen.Bottom.CurrencyDisplay:FindFirstChild("SpaceGemsDisplay") end
        else
            lbl = player.PlayerGui:FindFirstChild("SeedsDisplay", true)
            if not lbl then lbl = player.PlayerGui.GameGui.Screen.Bottom.CurrencyDisplay:FindFirstChild("SeedsDisplay") end
        end
        local textValue = lbl and lbl:FindFirstChild("Title") and lbl.Title.Text or ""
        if textValue ~= "" then
            local cleanText = string.lower(string.gsub(textValue, ",", ""))
            local numStr, suffix = string.match(cleanText, "([%d%.]+)%s*([kmb]?)")
            if numStr then
                val = tonumber(numStr)
                if suffix == "k" then val = val * 1000 elseif suffix == "m" then val = val * 1000000 elseif suffix == "b" then val = val * 1000000000 end
            end
        end
    end)
    return math.floor(val or 0)
end

-- 🧠 ดึงข้อมูลกระเป๋าแบบเจาะลึกผ่าน RAM (getgc)
local function GetRAMInventory()
    local targetUnits = {
        hasRaff = false, raffUid = nil, raffEquipped = false,
        hasLawn = false, lawnUid = nil, lawnEquipped = false,
        hasTomato = false, tomatoUid = nil, tomatoEquipped = false
    }
    local equippedUids = {}

    if type(getgc) == "function" then
        local gc = getgc(true)
        for _, obj in ipairs(gc) do
            if type(obj) == "table" then
                pcall(function()
                    for key, value in pairs(obj) do
                        if type(key) == "string" and string.find(key, "unique_") and type(value) == "table" then
                            if value.ItemData and type(value.ItemData) == "table" and value.ItemData.ID then
                                local uid = key
                                local itemName = string.lower(value.ItemData.ID)
                                local isEquipped = value.Equipped == true
                                
                                if isEquipped then table.insert(equippedUids, uid) end

                                if string.find(itemName, "rafflesia") then
                                    targetUnits.hasRaff = true; targetUnits.raffUid = uid; targetUnits.raffEquipped = isEquipped
                                elseif string.find(itemName, "lawnmower") then
                                    targetUnits.hasLawn = true; targetUnits.lawnUid = uid; targetUnits.lawnEquipped = isEquipped
                                elseif string.find(itemName, "tomato") or itemName == "unique_1" then
                                    targetUnits.hasTomato = true; targetUnits.tomatoUid = uid; targetUnits.tomatoEquipped = isEquipped
                                end
                            end
                        end
                    end
                end)
            end
        end
    end
    return targetUnits, equippedUids
end

local function SmartEquipRemote(requiredUnitName)
    local inv, equippedUids = GetRAMInventory()
    local targetUid = nil
    local isAlreadyEquipped = false

    if requiredUnitName == "Rafflesia" and inv.hasRaff then
        targetUid = inv.raffUid; isAlreadyEquipped = inv.raffEquipped
    elseif requiredUnitName == "Lawnmower" and inv.hasLawn then
        targetUid = inv.lawnUid; isAlreadyEquipped = inv.lawnEquipped
    elseif requiredUnitName == "Tomato" and inv.hasTomato then
        targetUid = inv.tomatoUid; isAlreadyEquipped = inv.tomatoEquipped
    end

    if not targetUid then
        DebugLog("❌ [EQUIP] ไม่มี " .. requiredUnitName .. " ในกระเป๋า!")
        return false
    end

    if isAlreadyEquipped then
        DebugLog("✅ [EQUIP] " .. requiredUnitName .. " ถูกใส่อยู่แล้ว! พร้อมลุยเลย!")
        return true
    end

    local rf = ReplicatedStorage:WaitForChild("RemoteFunctions", 3)
    if not rf or not rf:FindFirstChild("SetUnitEquipped") then return false end

    -- ถ้ากระเป๋าเต็ม (5/5) ให้ใช้ Remote ถอดออกก่อน
    if #equippedUids >= 5 then
        DebugLog("🧹 [EQUIP] ช่องใส่เต็ม! ถอดไอเทม: " .. equippedUids[1])
        pcall(function() rf.SetUnitEquipped:InvokeServer(equippedUids[1], false) end)
        task.wait(0.5)
    end

    DebugLog("🔄 [EQUIP] สวมใส่ " .. requiredUnitName .. " [" .. targetUid .. "] ผ่าน Remote...")
    local success = pcall(function() rf.SetUnitEquipped:InvokeServer(targetUid, true) end)
    task.wait(1)
    return success
end

