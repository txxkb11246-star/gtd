local function RunSpaceFarmMaster()
    local rf = ReplicatedStorage:WaitForChild("RemoteFunctions")
    local re = ReplicatedStorage:WaitForChild("RemoteEvents")
    
    local _, farmUnit, _, _ = GetRoutingPlan()
    SmartEquipRemote(farmUnit)
    
    local CENTER = Vector3.new(-17.668, -85.057, 30.373)
    local BASE   = Vector3.new(-12.406, -84.935, 30.372)
    local CF     = CFrame.new(-12.406, -84.935, 30.372, 0, 0, 1, 0, 1, 0, -1, 0, 0)
    
    local isEnd = {value = false}
    StartAutoSkip(isEnd)

    re.ShowGameEnd.OnClientEvent:Connect(function() isEnd.value = true end)

    local function runSpaceSession()
        isEnd.value = false
        local lastFire = 0
        local ammo = nil

        local sensor = RunService.Heartbeat:Connect(function()
            if isEnd.value then return end
            local nowTick = tick()
            local kZone, wZone = false, false
            
            local ents = Workspace.Map.Entities:GetChildren()
            local unitID = "unique_1"
            if farmUnit == "Rafflesia" then unitID = "unit_rafflesia" elseif farmUnit == "Lawnmower" then unitID = "unit_lawnmower" end

            for i = 1, #ents do
                local e = ents[i]
                if e.Name ~= unitID then
                    local p = e:GetPivot().Position
                    local d2 = (p.X - CENTER.X)^2 + (p.Z - CENTER.Z)^2
                    if d2 <= 64 then kZone = true; break elseif d2 <= 256 then wZone = true end
                end
            end
            
            local unitID = "unique_1"
            if farmUnit == "Rafflesia" then unitID = "unit_rafflesia" elseif farmUnit == "Lawnmower" then unitID = "unit_lawnmower" end

            if wZone and not ammo then
                local rX, rZ = (math.random() * 2 - 1) * 1.2, (math.random() * 2 - 1) * 1.2
                local fP, fC = BASE + Vector3.new(rX, 0, rZ), CF + Vector3.new(rX, 0, rZ)
                ammo = {unitID, {Valid=true, PathIndex=3, Position=fP, DistanceAlongPath=218.56, CF=fC, Rotation=180}}
            end
            
            if kZone and nowTick >= lastFire and ammo then
                local currentAmmo = ammo
                task.spawn(function() pcall(function() rf.PlaceUnit:InvokeServer(unpack(currentAmmo)) end) end)
                ammo = nil; lastFire = nowTick + 1.25
            end
        end)

        pcall(function() rf.ChangeTickSpeed:InvokeServer(2) end)
        task.wait(2)
        pcall(function() rf.PlaceDifficultyVote:InvokeServer("dif_apocalypse") end)
        
        while not isEnd.value do task.wait(1) end
        sensor:Disconnect()
    end

    while true do
        runSpaceSession()
        task.wait(3)
        if not CheckAndGoLobbyIfRich() then
            for i = 1, 2 do pcall(function() rf.RestartGame:InvokeServer() end); task.wait(2.5) end
        end
        task.wait(3)
    end
end

