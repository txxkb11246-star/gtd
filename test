    local stableCount = 0
    local lastSeeds = -1
    
    for i = 1, 30 do
        local _, _, totalUnits = ScanRAMInventory()
        local seeds = GetCurrentCurrency("seeds")
        
        if totalUnits > 0 then
            if seeds == lastSeeds and seeds ~= 250 then
                stableCount = stableCount + 1
            else
                stableCount = 0
            end
            lastSeeds = seeds
            
            if stableCount >= 2 then
                DebugLog("✅ [SYSTEM] ข้อมูลพร้อมใช้งาน! (ไอเทม: " .. totalUnits .. " ชิ้น, เงิน: " .. seeds .. ")")
