local function RunTomatoFarmMaster()
    local rf = ReplicatedStorage:WaitForChild("RemoteFunctions")
    local re = ReplicatedStorage:WaitForChild("RemoteEvents")
    
    local _, farmUnit, _, _ = GetRoutingPlan()
    SmartEquipRemote(farmUnit)
    
    local isEnd = {value = false}
    StartAutoSkip(isEnd)

    local bases = { 
        Vector3.new(-332.06, 61.68, -133.44), Vector3.new(-332.03, 61.68, -129.35), 
        Vector3.new(-328.53, 61.68, -133.47), Vector3.new(-328.60, 61.68, -129.72), 
        Vector3.new(-331.86, 61.68, -124.83), Vector3.new(-328.18, 61.68, -125.21), 
        Vector3.new(-324.44, 61.68, -133.87), Vector3.new(-324.18, 61.68, -128.84), 
        Vector3.new(-320.98, 61.68, -133.42), Vector3.new(-320.60, 61.68, -128.63), 
        Vector3.new(-327.70, 61.68, -120.67), Vector3.new(-331.38, 61.68, -119.84), 
        Vector3.new(-316.99, 61.68, -128.76), Vector3.new(-316.98, 61.68, -132.82), 
        Vector3.new(-338.77, 61.68, -217.81) 
    }

    local history = {}
    local function getCash()
        local c = 0
        pcall(function()
            local text = LP.PlayerGui.GameGui.Screen.Bottom.CurrencyDisplay.Cash.Text
            local cleaned = text:upper():gsub(",", "")
            if cleaned:find("K") then c = tonumber((cleaned:gsub("K", ""))) * 1000 else c = tonumber(cleaned:match("%d+")) end
        end)
        return math.floor(c or 0)
    end
    
    local function waitCash(v) 
        while not isEnd.value do if getCash() >= v then break end; task.wait(0.3) end 
    end
    
    local function findID(unitID)
        local list = Workspace.Map.Entities:GetChildren()
        for i = 1, #list do
            local e = list[i]
            local id = e:GetAttribute("ID")
            if e.Name == unitID and id and history[id] == nil then 
                history[id] = e; return id 
            end
        end
        return nil
    end

    re.ShowGameEnd.OnClientEvent:Connect(function() isEnd.value = true end)

    local function runTomatoSession()
        isEnd.value = false
        history = {}

        pcall(function() rf.ChangeTickSpeed:InvokeServer(2) end)
        task.wait(2.2)
        pcall(function() rf:WaitForChild("PlaceDifficultyVote"):InvokeServer("dif_easy") end)
        task.wait(5.5)
        
        local unitID = "unique_1"
        if farmUnit == "Rafflesia" then unitID = "unit_rafflesia" elseif farmUnit == "Lawnmower" then unitID = "unit_lawnmower" end

        for i = 1, #bases do
            if isEnd.value then break end
            local b = bases[i]
            local uID = nil
            local timeout = tick() + 5 
            
            repeat
                if isEnd.value then break end
                local fP = b + Vector3.new((math.random()*2-1)*1.5, 0, (math.random()*2-1)*1.5)
                pcall(function() rf.PlaceUnit:InvokeServer(unitID, {Valid=true, PathIndex=1, Position=fP, DistanceAlongPath=0, CF=CFrame.new(fP), Rotation=180}) end)
                task.wait(0.7)
                uID = findID(unitID)
            until uID or isEnd.value or tick() > timeout
            
            if uID then
                waitCash(125); pcall(function() rf.UpgradeUnit:InvokeServer(uID) end)
                waitCash(175); pcall(function() rf.UpgradeUnit:InvokeServer(uID) end)
                waitCash(350); pcall(function() rf.UpgradeUnit:InvokeServer(uID) end)
                waitCash(500); pcall(function() rf.UpgradeUnit:InvokeServer(uID) end)
            end
            task.wait(0.2)
        end
        
        while not isEnd.value do task.wait(1) end
    end

    while true do
        runTomatoSession()
        task.wait(3)
        if not CheckAndGoLobbyIfRich() then
            for i = 1, 2 do pcall(function() rf.RestartGame:InvokeServer() end); task.wait(2.5) end
        end
        task.wait(3)
    end
end

