-- 🧠 3.1) LOBBY RAM SCANNER (ทำแค่ครั้งเดียวตอนอยู่ Lobby)
local CachedInventory = { hasRaff = false, hasLawn = false, hasTomato = false }

local function ScanRAMInventory()
    DebugLog("🔍 [SYSTEM] สแกนกระเป๋าด้วย RAM (getgc)...")
    local targetUnits = {
        hasRaff = false, raffUid = nil, raffEquipped = false,
        hasLawn = false, lawnUid = nil, lawnEquipped = false,
        hasTomato = false, tomatoUid = nil, tomatoEquipped = false
    }
    local equippedUids = {}

    if type(getgc) == "function" then
        pcall(function()
            local gc = getgc(true)
            for _, obj in ipairs(gc) do
                if type(obj) == "table" then
                    for key, val in pairs(obj) do
                        if type(key) == "string" and string.find(key, "unique_") and type(val) == "table" then
                            if val.ItemData and type(val.ItemData) == "table" and val.ItemData.ID then
                                local uid = key
                                local itemName = string.lower(val.ItemData.ID)
                                local isEquipped = val.Equipped == true
                                
                                if isEquipped then table.insert(equippedUids, uid) end

                                if string.find(itemName, "rafflesia") then
                                    targetUnits.hasRaff = true; targetUnits.raffUid = uid; targetUnits.raffEquipped = isEquipped
                                elseif string.find(itemName, "lawnmower") then
                                    targetUnits.hasLawn = true; targetUnits.lawnUid = uid; targetUnits.lawnEquipped = isEquipped
                                elseif string.find(itemName, "tomato") or itemName == "unique_1" then
                                    targetUnits.hasTomato = true; targetUnits.tomatoUid = uid; targetUnits.tomatoEquipped = isEquipped
                                end
                            end
                        end
                    end
                end
            end
        end)
    end
    
    CachedInventory.hasRaff = targetUnits.hasRaff
    CachedInventory.hasLawn = targetUnits.hasLawn
    CachedInventory.hasTomato = targetUnits.hasTomato
    
    return targetUnits, equippedUids
end

-- 🌿 3.2) FARM BACKPACK SCANNER (เบาเครื่องสุดๆ ใช้ตอนลงด่าน)
local function GetFarmInventory()
    local hasRaff, hasLawn = false, false
    local function chk(txt)
        if not txt then return end
        txt = string.lower(txt)
        if string.find(txt, "raff") then hasRaff = true end
        if string.find(txt, "lawn") then hasLawn = true end
    end
    
    pcall(function() for _, v in pairs(LP.Backpack:GetChildren()) do chk(v.Name) end end)
    pcall(function() if LP.Character then for _, v in pairs(LP.Character:GetChildren()) do chk(v.Name) end end end)
    pcall(function()
        local hb = LP.PlayerGui:FindFirstChild("BackpackGui")
        if hb and hb:FindFirstChild("Backpack") and hb.Backpack:FindFirstChild("Hotbar") then
            for i = 1, 10 do
                local slot = hb.Backpack.Hotbar:FindFirstChild(tostring(i))
                if slot and slot:FindFirstChild("ToolName") then chk(slot.ToolName.Text) end
            end
        end
    end)
    return hasRaff, hasLawn
end

