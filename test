            deployLawnmower(2, DATA.LAW3, "LAW3")
            
            DebugLog("⏱️ [STEP 4] รอ 13 วินาที เพื่อวางตัวที่ 4 (จุดที่ 1)")
            if not safeWait(13) then return end
            deployLawnmower(1, DATA.LAW4, "LAW4_1")

            DebugLog("⏱️ [STEP 4.1] รอ 2.3 วินาที เพื่อวางตัวที่ 4 (จุดที่ 2)")
            if not safeWait(2.3) then return end
            deployLawnmower(1, DATA.LAW4, "LAW4_2")

            DebugLog("⏱️ [STEP 4.2] รอ 2.8 วินาที เพื่อวางตัวที่ 4 (จุดที่ 3)")
            if not safeWait(2.8) then return end
            deployLawnmower(1, DATA.LAW4, "LAW4_3")

            DebugLog("⏱️ [STEP 5] รอ 2.3 วินาที เพื่อวางตัวที่ 5")
            if not safeWait(2.3) then return end
            deployLawnmower(1, DATA.LAW4, "LAW5")

            DebugLog("⏱️ [STEP 6] รอ 2.3 วินาที เพื่อวางตัวที่ 6")
            if not safeWait(2.3) then return end
            deployLawnmower(1, DATA.LAW4, "LAW6")

            DebugLog("🔥 [SPAM MODE] เริ่มวางรัวๆ 30 ตัว (LAW 7 ถึง LAW 36) ดีเลย์ 0.1 วิ!")
