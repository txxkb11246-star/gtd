    else RunTomatoFarmMaster() end
end

-- ==========================================
-- [11] SYSTEM BOOTSTRAP
-- ==========================================
DebugLog("⏳ [SYSTEM] รอให้เซิร์ฟเวอร์ยัดข้อมูลใส่กระเป๋า (6 วินาที)...")
task.wait(6)

-- 🔥 เปิดระบบตั้งเวลาบังคับ Hop กลับไปเก็บไข่หลังจากฟาร์มครบเวลา
StartFarmTimerMonitor()

if isInLobby() then 
    -- 🛑 สั่งรัน Smart Sweeper V2 ก่อนเริ่มทำงานระบบ Lobby เพื่อเก็บไข่ให้หมดก่อนเดินเข้าวงวาร์ป
    local continueToFarm = ProcessSmartSweeperFirst()
    
    if continueToFarm then
        StartLobbyMasterEngine() 
    end
else 
    local _, farmUnit, _ = GetRoutingPlan()
    DebugLog("🎮 [FARM] สแกนกระเป๋าเสร็จสิ้น: AI ตัดสินใจเล่นโหมด " .. farmUnit)
    
    if farmUnit == "Rafflesia" then RunIceFarmMaster()
    elseif farmUnit == "Lawnmower" then 
        if CONFIG.SelectMap == "BGarden" or CONFIG.SelectMap == "AutoSeed" then 
            RunBGardenFarmMaster() 
        else 
            RunSpaceFarmMaster() 
        end
    else RunTomatoFarmMaster() end
end
