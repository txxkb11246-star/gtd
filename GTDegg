        local fired = false
        local function tryFire(target)
            local success = false
            pcall(function()
                if target.MouseButton1Click then
                    for _, connection in pairs(getconnections(target.MouseButton1Click)) do connection:Fire(); success = true end
                end
                if target.Activated then
                    for _, connection in pairs(getconnections(target.Activated)) do connection:Fire(); success = true end
                end
                if target.MouseButton1Down then
                    for _, connection in pairs(getconnections(target.MouseButton1Down)) do connection:Fire(); success = true end
                    for _, connection in pairs(getconnections(target.MouseButton1Up)) do connection:Fire(); success = true end
                end
            end)
            return success
        end
        
        fired = tryFire(guiObj)
        if not fired then
            for _, child in pairs(guiObj:GetDescendants()) do
                if child:IsA("GuiButton") then if tryFire(child) then fired = true; break end end
            end
        end

        if not fired then doVIM(guiObj) end
    end
end

local function IsInHotbar(unitName)
    local bUI = LP.PlayerGui:FindFirstChild("BackpackGui")
    if not bUI then return false end
    local hb = bUI.Backpack:FindFirstChild("Hotbar")
    if not hb then return false end
    
    local key = string.lower(unitName)
    for i = 1, 10 do
        local slot = hb:FindFirstChild(tostring(i))
        if slot and slot:FindFirstChild("ToolName") then
            if string.find(string.lower(slot.ToolName.Text), key) then return true end
        end
    end
    return false
end

local function TripleLayerEquip(shortName, fullName)
    if IsInHotbar(shortName) then return true end
    
    pcall(function()
        local rf = ReplicatedStorage:WaitForChild("RemoteFunctions", 3)
        if rf and rf:FindFirstChild("SetUnitEquipped") then
            if shortName == "Tomato" then
                rf.SetUnitEquipped:InvokeServer("unique_1", true)
            elseif shortName == "Lawnmower" then
                rf.SetUnitEquipped:InvokeServer("unit_lawnmower", true)
            elseif shortName == "Rafflesia" then
                rf.SetUnitEquipped:InvokeServer("unit_rafflesia", true)
            end
        end
    end)

    task.wait(1.5)
    if IsInHotbar(shortName) then 
        DebugLog("✅ [EQUIP] สวมใส่ " .. shortName .. " ด้วย Remote สำเร็จ!")
        return true 
    end
    
    pcall(function()
        local main = LP.PlayerGui:WaitForChild("GameGui", 10).Screen
        if main.Middle.Inventory.Visible == false then 
            local invBtn = main.Left.Sidebar.Items.Inventory.Items.Button
            ClickButton(invBtn)
            task.wait(3) 
        end
        
        local targetBtn = nil
        local scroll = main.Middle.Inventory.Inventory.Frame.Items.Items.ScrollingFrame
        local searchName = string.lower(fullName)
        
        if shortName == "Tomato" then searchName = "unique_1" end
        
        for _, v in pairs(scroll:GetDescendants()) do
            local vName = string.lower(v.Name)
            if vName == searchName or string.find(vName, string.lower(shortName)) then
                targetBtn = v
                break
            end
        end
        
        if targetBtn then 
            for i = 1, 5 do 
                ClickButton(targetBtn)
                task.wait(1.5)
                if IsInHotbar(shortName) then break end 
            end 
        end
    end)
    return IsInHotbar(shortName)
end

