local function SafeNum(input)
    if type(input) == "number" then return math.floor(input) end
    local s = tostring(input):upper():gsub(",", "")
    local nStr = s:match("[%d%.]+")
    local val = tonumber(nStr) or 0
    if s:find("K") then val = val * 1000 elseif s:find("M") then val = val * 1000000 end
    return math.floor(val)
end

local function GetTrueOwnedInventory()
    local hasRaff = false
    local hasLawn = false

    local function checkStr(txt)
        if not txt then return end
        txt = string.lower(txt)
        if string.find(txt, "raff") then hasRaff = true end
        if string.find(txt, "lawn") then hasLawn = true end
    end

    pcall(function()
        for _, v in pairs(LP.Backpack:GetChildren()) do checkStr(v.Name) end
        if LP.Character then
            for _, v in pairs(LP.Character:GetChildren()) do checkStr(v.Name) end
        end
    end)

    pcall(function()
        local bUI = LP.PlayerGui:FindFirstChild("BackpackGui")
        if bUI and bUI:FindFirstChild("Backpack") and bUI.Backpack:FindFirstChild("Hotbar") then
            for i = 1, 10 do
                local slot = bUI.Backpack.Hotbar:FindFirstChild(tostring(i))
                if slot and slot:FindFirstChild("ToolName") then
                    checkStr(slot.ToolName.Text)
                end
            end
        end
    end)

    pcall(function()
        local mainUI = LP.PlayerGui.GameGui.Screen
        local scroll = mainUI.Middle.Inventory.Inventory.Frame.Items.Items.ScrollingFrame
        for _, v in pairs(scroll:GetDescendants()) do
            checkStr(v.Name)
            if v:IsA("TextLabel") or v:IsA("TextButton") then checkStr(v.Text) end
        end
    end)

    return hasRaff, hasLawn
end

local function GetRoutingPlan()
    local hasRaff, hasLawn = GetTrueOwnedInventory()
    local targetMapName = "map_farm"
    local farmUnit = "Tomato"
    local shouldRollGacha = false

    if CONFIG.SelectMap == "AutoSeed" then
        if hasRaff then
            targetMapName = "map_christmas"; farmUnit = "Rafflesia"; shouldRollGacha = false
        elseif hasLawn then
            targetMapName = "map_back_garden"; farmUnit = "Lawnmower"; shouldRollGacha = false 
        else
            targetMapName = "map_farm"; farmUnit = "Tomato"; shouldRollGacha = true
        end
    elseif CONFIG.SelectMap == "AutoGem" then
        if hasLawn then
            targetMapName = "map_space"; farmUnit = "Lawnmower"; shouldRollGacha = false 
        else
            targetMapName = "map_farm"; farmUnit = "Tomato"; shouldRollGacha = true
        end
    elseif CONFIG.SelectMap == "Ice" then
        targetMapName = "map_christmas"
        if hasRaff then farmUnit = "Rafflesia" elseif hasLawn then farmUnit = "Lawnmower" else farmUnit = "Tomato" end
        shouldRollGacha = not hasRaff
    elseif CONFIG.SelectMap == "Space" then
        targetMapName = "map_space"
        if hasLawn then farmUnit = "Lawnmower" else farmUnit = "Tomato" end
        shouldRollGacha = not hasLawn
    elseif CONFIG.SelectMap == "BGarden" then
        targetMapName = "map_back_garden"
        if hasLawn then farmUnit = "Lawnmower" else farmUnit = "Tomato" end
        shouldRollGacha = not hasLawn
    end

    return targetMapName, farmUnit, shouldRollGacha
end

