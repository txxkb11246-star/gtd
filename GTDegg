local function ScanAndSortEggs(livePrices)
    DebugLog("🌍 กำลังสแกนหาไข่ในแผนที่ และจัดเรียงจากแพงไปถูก...")
    local itemsFound = {}
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local collectID = obj:GetAttribute("ID")
        local itemType = obj:GetAttribute("ItemId")
        
        if type(collectID) == "number" and type(itemType) == "string" then
            local currentPrice = 0
            local typeLower = string.lower(itemType)
            
            for id, price in pairs(livePrices) do
                if string.find(id, typeLower) then
                    if price > currentPrice then 
                        currentPrice = price 
                    end
                end
            end
            
            table.insert(itemsFound, {
                Object = obj,
                ID = collectID,
                Price = currentPrice,
                Name = itemType
            })
        end
    end
    
    table.sort(itemsFound, function(a, b)
        return a.Price > b.Price
    end)
    
    DebugLog("✅ สแกนเสร็จสิ้น! พบไข่ทั้งหมด " .. tostring(#itemsFound) .. " ชิ้น")
    return itemsFound
end

local function CollectSmartly(itemList, remoteEvent)
    if #itemList == 0 then
        DebugLog("⚠️ แมพนี้เกลี้ยงแล้ว ไม่มีอะไรให้เก็บ")
        return
    end

    DebugLog("🚀 เริ่มทำการดูดไข่ (กวาดทั้งแมพ ไล่จากแพงสุดไปถูกสุด)...")
    local successCount = 0
    
    for index, item in ipairs(itemList) do
        remoteEvent:FireServer(item.ID)
        successCount = successCount + 1
        
        DebugLog(string.format("  💎 [เก็บฟองที่ %d/%d] ราคาประเมิน: %d | ชนิด: %s", index, #itemList, item.Price, item.Name))
        task.wait(0.05) 
    end
    
    DebugLog("🎉 กวาดไข่ทุกฟองในเซิร์ฟเวอร์นี้เสร็จสิ้น! ส่งคำสั่งไป " .. tostring(successCount) .. " ชิ้น")
    task.wait(2) 
end

local function ExecuteServerHop()
    DebugLog("🔄 กำลังย้ายเซิร์ฟเวอร์...")
    
    local placeId = game.PlaceId
    local currentJobId = game.JobId
    local serversUrl = "https://games.roblox.com/v1/games/" .. tostring(placeId) .. "/servers/Public?sortOrder=Desc&limit=100"
    
    local success, result = pcall(function() return game:HttpGet(serversUrl) end)
    
    if success and result then
        local decodeSuccess, decodedData = pcall(function() return HttpService:JSONDecode(result) end)
        if decodeSuccess and decodedData and decodedData.data then
            for _, serverInfo in ipairs(decodedData.data) do
                if type(serverInfo) == "table" and serverInfo.playing < serverInfo.maxPlayers and serverInfo.id ~= currentJobId then
                    DebugLog("🚀 วาร์ปไปที่เซิร์ฟเวอร์ผู้เล่น " .. tostring(serverInfo.playing) .. " คน...")
                    TeleportService:TeleportToPlaceInstance(placeId, serverInfo.id, LP)
                    task.wait(10)
                end
            end
        end
    end
    
    DebugLog("⚠️ ใช้งานระบบสุ่มย้ายเซิร์ฟเวอร์สำรอง...")
    TeleportService:Teleport(placeId, LP)
end

