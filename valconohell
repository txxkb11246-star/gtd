local function GetTridentCount()
    if not InventoryTableCache then UpdateInventoryCache() end
    local count = 0
    if InventoryTableCache then
        for uid, data in pairs(InventoryTableCache) do
            if type(uid) == "string" then
                if string.find(uid, "unique_", 1, true) then
                    if data.ItemData and data.ItemData.ID and data.ItemData.ID == "unit_trident" then
                        count = count + 1
                    end
                end
            end
        end
    end
    return count
end

