                    pathDir = pathPart.CFrame.LookVector
                elseif size.Y > size.X and size.Y > size.Z then
                    pathDir = pathPart.CFrame.UpVector
                end
                
                finalPos = config.pos + (pathDir * jitter)
                finalCF = config.cf + (pathDir * jitter)
                finalDist = config.dist + jitter
                
                debugLog("Rafflesia Jitter applied | Dir: " .. tostring(pathDir) .. " | Amount: " .. tostring(jitter))
            else
                debugLog("Failed to find any path part in Workspace.Map.Path!")
            end
        else
            finalPos = getRandPos(config.pos)
            finalCF = CFrame.new(finalPos) * (config.cf - config.cf.Position)
            finalDist = config.dist
        end
        
        local id = nil
        local attempt = 0
        
        repeat
            if forceRestart then break end
            attempt = attempt + 1
            
            local placeArgs = {
                Valid = true, PathIndex = path, Position = finalPos, DistanceAlongPath = finalDist, CF = finalCF, Rotation = 180
            }
            
            debugLog("Attempting PlaceUnit: " .. unitName .. " (Try " .. attempt .. ")")
            if attempt == 1 then
                debugLog("Args -> Pos: " .. tostring(placeArgs.Position) .. " | Dist: " .. tostring(placeArgs.DistanceAlongPath))
            end
            
            local ok, invokeResult = pcall(function()
                return PlaceUnit:InvokeServer(unitName, placeArgs)
            end)
            
            debugLog("PlaceUnit Result -> OK: " .. tostring(ok) .. " | Return: " .. tostring(invokeResult))
            
            -- If placement didn't explicitly fail, try to fetch the ID
            if ok and invokeResult ~= false and invokeResult ~= "Invalid Placement" then 
                task.wait(0.5)
                id = findNewUnitId(unitName)
                debugLog("findNewUnitId result -> " .. tostring(id))
            end
            
            if not id then task.wait(0.5) end
        until id ~= nil or forceRestart
        
        print(id and "✅ Placed: "..unitName or "❌ Failed: "..unitName)
        
        if waitTime and waitTime > 0 then
            local start = tick()
            while tick() - start < waitTime do if forceRestart then break end task.wait(0.5) end
        end
        
        return id
    end

    local function cleanup()
