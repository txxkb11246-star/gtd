local function ScanRAMForInventory()
    if type(getgc) ~= "function" then
        warn("❌ Executor ไม่รองรับ getgc()")
        return nil
    end

    local gc = getgc(true)
    local inventoryTable = nil

    for _, obj in ipairs(gc) do
        if type(obj) == "table" then
            pcall(function()
                for key, value in pairs(obj) do
                    if type(key) == "string" and string.find(key, "unique_") and type(value) == "table" then
                        if value.ItemData and type(value.ItemData) == "table" and value.ItemData.ID then
                            inventoryTable = obj
                            break
                        end
                    end
                end
            end)
            if inventoryTable then break end
        end
    end

    if inventoryTable then
        local parsedInv = {}
        pcall(function()
            for uid, data in pairs(inventoryTable) do
                if type(uid) == "string" and string.find(uid, "unique_") then
                    table.insert(parsedInv, {
                        uid = uid,
                        name = data.ItemData.ID or "Unknown",
                        equipped = data.Equipped == true
                    })
                end
            end
        end)
        
        table.clear(gc)
        gc = nil
        
        if #parsedInv > 0 then
            return parsedInv
        end
    end
    
    table.clear(gc)
    gc = nil
    
    return nil
end

