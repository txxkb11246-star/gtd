                                task.spawn(function()
                                    pcall(function()
                                        local placeRemote = RemoteFuncs:WaitForChild("PlaceUnit")
                                        placeRemote:InvokeServer(dynamicUnitID, {
                                            ["CF"] = cfToPlace,
                                            ["Rotation"] = 180, 
                                            ["Valid"] = true, 
                                            ["Position"] = cfToPlace.Position
                                        })
                                    end)
                                end)
                            end
                        end
                        
                    else
                        -- STANDARD EP5-EP8, EP10 & EP13 PLACEMENT LOGIC
                        local unitCount = 0
                        pcall(function()
                            local map = Workspace:FindFirstChild("Map")
                            if map then
                                local entities = map:FindFirstChild("Entities")
                                if entities then
                                    local children = entities:GetChildren()
                                    for i = 1, #children do
                                        local ent = children[i]
                                        local lowerName = string.lower(ent.Name)
                                        if string.find(lowerName, string.lower(dynamicUnitID), 1, true) then
                                            unitCount = unitCount + 1
                                            local id = ent:GetAttribute("ID")
                                            if id then
                                                pcall(function()
                                                    local upgradeRemote = RemoteFuncs:WaitForChild("UpgradeUnit")
                                                    upgradeRemote:InvokeServer(id)
                                                end)
                                            end
                                        end
                                    end
                                end
                            end
                        end)

                        if unitCount == 0 then
                            local basePos = CONFIG[currentQuest.."_Pos"]
                            local rX = (math.random() * 3) - 1.5
                            local rZ = (math.random() * 3) - 1.5
                            local finalPos = Vector3.new(
                                basePos.X + rX, 
                                basePos.Y, 
                                basePos.Z + rZ
                            )
                            task.spawn(function()
                                pcall(function() 
                                    local placeRemote = RemoteFuncs:WaitForChild("PlaceUnit")
                                    placeRemote:InvokeServer(dynamicUnitID, {
                                        ["CF"] = CFrame.new(finalPos) * CFrame.Angles(0, math.rad(180), 0), 
                                        ["Rotation"] = 180, 
                                        ["Valid"] = true, 
                                        ["Position"] = finalPos
                                    }) 
                                end)
                            end)
                        end
                    end
                    task.wait(0.5) 
                end
                
                if conn then 
                    conn:Disconnect() 
                end
                task.wait(2)
                
                if STATE[currentQuest.."_Done"] then
                    DLog("MATCH", "📦 " .. currentQuest .. " Complete! Teleporting back to Lobby...")
                    pcall(function()
                        local returnToLobby = RemoteFuncs:FindFirstChild("ReturnToLobby")
                        if returnToLobby then 
                            returnToLobby:InvokeServer() 
                        end
                        local leaveGame = RemoteFuncs:FindFirstChild("LeaveGame")
                        if leaveGame then 
                            leaveGame:InvokeServer() 
                        end
                    end)
                    task.wait(2)
                    pcall(function() 
                        local placeId = game.PlaceId
                        TeleportService:Teleport(placeId, LocalPlayer) 
                    end)
                    task.wait(9e9)
                else
                    DLog("MATCH", "🔄 Map finished but quest not complete. Restarting Game...")
                    pcall(function() 
                        local restartRemote = RemoteFuncs:WaitForChild("RestartGame")
                        restartRemote:InvokeServer() 
                    end)
                    task.wait(10)
                end
            end
        end
        task.wait(2)
    end
end)

