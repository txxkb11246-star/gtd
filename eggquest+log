local InventoryTableCache = nil

local function UpdateInventoryCache()
    local gc = getgc(true)
    for i = 1, #gc do
        local obj = gc[i]
        if type(obj) == "table" then
            pcall(function()
                for uid, data in pairs(obj) do
                    if type(uid) == "string" then
                        if string.find(uid, "unique_", 1, true) then
                            if data.ItemData then
                                if data.ItemData.ID then
                                    InventoryTableCache = obj
                                end
                            end
                        end
                    end
                end
            end)
            if InventoryTableCache then 
                break 
            end
        end
    end
end

local function GetUIDByName(targetName)
    if not InventoryTableCache then 
        UpdateInventoryCache() 
    end
    if InventoryTableCache then
        for uid, data in pairs(InventoryTableCache) do
            if type(uid) == "string" then
                if string.find(uid, "unique_", 1, true) then
                    if data.ItemData then
                        if data.ItemData.ID == targetName then
                            return uid
                        end
                    end
                end
            end
        end
    end
    return nil
end

local function GetValidUnitBaseID()
    if not InventoryTableCache then 
        UpdateInventoryCache() 
    end
    
    local fallbackUnit = nil
    if InventoryTableCache then
        -- 1. ลำดับแรก หา Catapult เสมอ
        for uid, data in pairs(InventoryTableCache) do
            if type(uid) == "string" then
                if string.find(uid, "unique_", 1, true) then
                    if data.ItemData then
                        if data.ItemData.ID == "unit_egg_catapult" then
                            return "unit_egg_catapult"
                        end
                    end
                end
            end
        end
        
        -- 2. ถ้าไม่มี ค่อยหาตัวที่ใส่อยู่หรือตัวแรกสุดที่ใส่ได้
        for uid, data in pairs(InventoryTableCache) do
            if type(uid) == "string" then
                if string.find(uid, "unique_", 1, true) then
                    if data.ItemData then
                        if data.ItemData.ID then
                            local id = data.ItemData.ID
                            if id ~= "unit_rafflesia" then
                                if id ~= "unit_lawnmower" then
                                    if string.find(id, "unit_", 1, true) then
                                        if data.Equipped == true or data.EquippedSlot then
                                            return id
                                        end
                                        if not fallbackUnit then 
                                            fallbackUnit = id 
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
        
        if InventoryTableCache["unique_1"] then
            if InventoryTableCache["unique_1"].ItemData then
                local id = InventoryTableCache["unique_1"].ItemData.ID
                if id ~= "unit_rafflesia" then
                    if id ~= "unit_lawnmower" then 
                        return id 
                    end
                end
            end
        end
    end
    
    if fallbackUnit then
        return fallbackUnit
    else
        return "unit_egg_catapult"
    end
end

