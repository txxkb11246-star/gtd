local function GetCurrentSeedsNumber()
    local s = 999999999
    pcall(function()
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            local gameGui = playerGui:FindFirstChild("GameGui")
            if gameGui then
                local screen = gameGui:FindFirstChild("Screen")
                if screen then
                    local bottom = screen:FindFirstChild("Bottom")
                    if bottom then
                        local currencyDisplay = bottom:FindFirstChild("CurrencyDisplay")
                        if currencyDisplay then
                            local seedsDisplay = currencyDisplay:FindFirstChild("SeedsDisplay")
                            if seedsDisplay then
                                local title = seedsDisplay:FindFirstChild("Title")
                                if title then
                                    local t = title.Text
                                    t = string.gsub(t, ",", "")
                                    
                                    local numStr, suffix = string.match(t, "([%d%.]+)([KMB]?)")
                                    if numStr then
                                        local num = tonumber(numStr)
                                        if num then
                                            if suffix == "K" then 
                                                num = num * 1000
                                            elseif suffix == "M" then 
                                                num = num * 1000000
                                            elseif suffix == "B" then 
                                                num = num * 1000000000 
                                            end
                                            s = math.floor(num)
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
    return s
end

