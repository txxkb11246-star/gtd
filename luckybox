-- 🔍 ระบบสแกนหาข้อมูล Inventory ผู้เล่นในแรม (v8 - Global Table Cache)
-- หลักการ:
--   1. สแกนหาตาราง Inventory แค่ "ตารางเดียว" แล้วจำไว้ใช้ตลอดกาล
--   2. ต่อให้เควสใหม่ยังเป็น 0 (ยังไม่มีคีย์ในตาราง) ก็ไม่ทำให้สคริปต์สแกน GC ซ้ำ
--   3. 0 RAM Leak แน่นอน เพราะอ่านค่าจากตารางตรงๆ
--=============================================

local _inventoryTable = nil
local _lastScanTime = 0
local KNOWN_KEYS = {
    "cl_lucky26_flower", "cl_lucky26_fence", "cl_lucky26_profile", 
    "cl_lucky26_barn", "cl_lucky26_tree", "cl_lucky26_gnome",
    "cl_lucky26_daily", "cl_lucky26_daily_group"
}

GetProgress = function(refKey)
    -- 1. ถ้ามีตารางอยู่แล้ว ลองอ่านค่าเลย (เร็วสุดๆ)
    if _inventoryTable then
        local ok, val = pcall(function() return rawget(_inventoryTable, refKey) end)
        if ok then
            if type(val) == "number" then return val end
            if val == nil then return 0 end -- คีย์ยังไม่ถูกสร้าง ถือว่าเป็น 0 ทันที (ไม่สแกนซ้ำ!)
        else
            _inventoryTable = nil -- ตารางพัง รีเซ็ต
        end
    end
    
    -- 2. ถ้ายังไม่เคยหาตารางเจอ ให้สแกนหา (Rate Limit 2 วิ ป้องกันแรมบวม)
    local now = os.clock()
    if (now - _lastScanTime) < 2 then
        return 0
    end
    _lastScanTime = now
    
    local gc = getgc(true)
    local bestTable = nil
    local maxKeys = 0
    
    for _, v in pairs(gc) do
        if type(v) == "table" then
            local ok, keyCount = pcall(function()
                -- ลองหาคีย์ที่น่าจะมีอยู่ในตาราง (O(1) เช็คเร็วมาก)
                local hasKnown = false
                local isGlobalStats = false
                
                for _, k in ipairs(KNOWN_KEYS) do
                    local val = rawget(v, k)
                    if type(val) == "number" then
                        hasKnown = true
                        -- ค่าของเควสปกติจะอยู่แค่ 1-50 (Limit) ถ้าค่าเกิน 50 
                        -- แปลว่านี่คือตาราง 'สถิติรวมของทั้งเซิร์ฟเวอร์ (Global Stats)' ไม่ใช่กระเป๋าผู้เล่น
                        if val > 50 then
                            isGlobalStats = true
                            break
                        end
                    end
                end
                
                if not hasKnown or isGlobalStats then return 0 end
                
                -- นับจำนวนคีย์ในตารางนี้ เพื่อหาตารางกระเป๋าที่ใหญ่ที่สุด (กันไปจำตารางขยะ/ชั่วคราว)
                local count = 0
                for _ in pairs(v) do count = count + 1 end
                return count
            end)
            
            if ok and keyCount > maxKeys then
                maxKeys = keyCount
                bestTable = v
            end
        end
    end
    
    table.clear(gc)
    gc = nil
    
    if bestTable then
        print(string.format("🎯 [Scanner] จำตาราง Inventory หลักแล้ว! (มีข้อมูลในกระเป๋า %d ชิ้น)", maxKeys))
        _inventoryTable = bestTable
        
        -- อ่านค่าอีกรอบหลังจากหาตารางเจอ
        local ok, val = pcall(function() return rawget(_inventoryTable, refKey) end)
        if ok and type(val) == "number" then return val end
    end
    
    return 0
end

