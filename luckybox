--=============================================
-- 🔄 ระบบ Server Hop (ย้ายเซิร์ฟเวอร์)
--=============================================
local function HopServer(findLeastPlayers)
    local HttpService = game:GetService("HttpService")
    local TeleportService = game:GetService("TeleportService")
    local PlaceId = game.PlaceId
    local JobId = game.JobId
    
    local sortOrder = findLeastPlayers and "Asc" or "Desc"
    local logMsg = findLeastPlayers and "น้อยที่สุด" or "เยอะที่สุด (แต่ไม่เต็ม)"
    
    print("🔄 [Server Hop] กำลังค้นหาเซิร์ฟเวอร์ที่คน" .. logMsg .. "...")
    
    local success, result = pcall(function()
        -- ใช้ sortOrder ตามที่กำหนดเพื่อหาห้องคนเยอะ/คนน้อย
        local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=" .. sortOrder .. "&limit=100"
        local response = game:HttpGet(url)
        local data = HttpService:JSONDecode(response)
        
        local env = (getgenv and getgenv()) or _G
        env.BlacklistedServers = env.BlacklistedServers or {}
        env.BlacklistedServers[JobId] = true -- แบล็กลิสต์ห้องปัจจุบันและห้องที่เคยไปมาแล้ว
        
        local availableServers = {}
        for _, server in ipairs(data.data) do
            -- หาเซิร์ฟที่คนยังไม่เต็ม และต้องไม่ใช่ห้องที่เคยไปมาแล้วใน Session นี้
            if type(server) == "table" and server.playing and server.maxPlayers then
                if server.playing < server.maxPlayers and server.id ~= JobId and not env.BlacklistedServers[server.id] then
                    table.insert(availableServers, server)
                    if not findLeastPlayers then
                        break -- ถ้าหาห้องคนเยอะสุด (Desc) ให้เอาห้องแรกที่เจอเลยตามปกติ
                    end
                end
            end
        end
        
        if #availableServers > 0 then
            local selectedServer
            if findLeastPlayers then
                -- ใช้ Random.new() เพื่อให้สุ่มได้ผลลัพธ์ใหม่จริงๆ ทุกครั้ง (แก้ปัญหา math.random ล็อกเลขเดิม)
                selectedServer = availableServers[Random.new():NextInteger(1, #availableServers)]
            else
                selectedServer = availableServers[1]
            end
            
            print(string.format("🔄 [Server Hop] พบห้องเหมาะสม! คนเล่น: %d/%d | กำลังย้ายเซิร์ฟเวอร์...", selectedServer.playing, selectedServer.maxPlayers))
            TeleportService:TeleportToPlaceInstance(PlaceId, selectedServer.id, game.Players.LocalPlayer)
            task.wait(10)
        end
    end)
    
    if not success then
        warn("⚠️ [Server Hop] ค้นหา Server แบบเจาะจงไม่สำเร็จ ใช้การสุ่มย้ายห้องแทน (Fallback)")
        TeleportService:Teleport(PlaceId, game.Players.LocalPlayer)
    end
end

