-- 🎁 ระบบจัดการกล่องดรอป (Collector Thread)
--=============================================
task.spawn(function()
    local Workspace = game:GetService("Workspace")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local CollectRemote = ReplicatedStorage:WaitForChild("RemoteFunctions"):WaitForChild("CollectCollectable")
    
    -- ฟังก์ชันสำหรับตรวจสอบและเก็บกล่อง
    local function TryCollect(obj)
        -- เช็คชื่อ Object
        if obj.Name == "Collectable" then
            -- เช็คว่าเป็นของอีเวนต์ lucky26
            if obj:GetAttribute("CollectionId") == "lucky26" then
                local id = obj:GetAttribute("ID")
                local itemId = obj:GetAttribute("ItemId") or "ไม่ทราบชื่อ"
                
                if id and type(id) == "number" then
                    -- แยก Thread ป้องกันสคริปต์ค้างจาก InvokeServer
                    task.spawn(function()
                        local success, result = pcall(function()
                            return CollectRemote:InvokeServer(id)
                        end)
                        
                        if success then
                            print(string.format("🎁 [เก็บสำเร็จ] ชนิด: %s | ID: %d", tostring(itemId), id))
                        else
                            print(string.format("❌ [ล้มเหลว] ไม่สามารถเก็บ: %s | ID: %d", tostring(itemId), id))
                        end
                    end)
                    return true
                end
            end
        end
        return false
    end
    
    -- ระบบที่ 1: กวาดเก็บกล่องที่ตกค้างอยู่ใน Workspace ปัจจุบันทั้งหมด
    local children = Workspace:GetChildren()
    for i = 1, #children do
        TryCollect(children[i])
    end
    
    -- ระบบที่ 2: ดักจับกล่องที่กำลังจะดรอปใหม่
    Workspace.ChildAdded:Connect(function(obj)
        -- รอโหลด Attribute แป๊บนึงเผื่อเซิร์ฟเวอร์ส่งมาไม่ทัน
        task.wait(0.1)
        TryCollect(obj)
    end)
    
    print("✅ ระบบ Collector เริ่มทำงาน: ดักเก็บ Luckybox อัตโนมัติ")
end)
