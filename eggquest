        local RightPanel = MainCollectUI:WaitForChild("Right", 3)
        if RightPanel then
            -- 🎯 โฟกัสเฉพาะ Part 1 (easter26) เท่านั้นตามคำขอ
            local EasterTab = RightPanel:WaitForChild("easter26", 3)
            if EasterTab then
                local consTab = getconnections(EasterTab.MouseButton1Click)
                for i = 1, #consTab do
                    consTab[i]:Fire() 
                end
            end
        end

        task.wait(1.5) 

        local descendants = GameGui:GetDescendants()
        for i = 1, #descendants do
            local v = descendants[i]
            if v:IsA("TextLabel") then
                local textLower = string.lower(v.Text)
                if string.find(textLower, "owned") or string.find(textLower, "limit") or string.find(textLower, "left") then
                    
                    local currentType = ""
                    local parentGroup = v.Parent
                    if parentGroup then
                        local grandParent = parentGroup.Parent
                        if grandParent then
                            local gpDescendants = grandParent:GetDescendants()
                            for j = 1, #gpDescendants do
                                local child = gpDescendants[j]
                                if child:IsA("TextLabel") then
                                    if string.find(child.Text, CONFIG.EP1_Name) then 
                                        currentType = "EP1" 
                                    elseif string.find(child.Text, CONFIG.EP2_Name) then 
                                        currentType = "EP2" 
                                    elseif string.find(child.Text, CONFIG.EP3_Name) then 
                                        currentType = "EP3" 
                                    elseif string.find(child.Text, CONFIG.EP4_Name) then 
                                        currentType = "EP4" 
                                    elseif string.find(child.Text, CONFIG.EP5_Name) then 
                                        currentType = "EP5" 
                                    elseif string.find(child.Text, CONFIG.EP6_Name) then 
                                        currentType = "EP6" 
                                    elseif string.find(child.Text, CONFIG.EP7_Name) or string.find(child.Text, "Island") then 
                                        currentType = "EP7" 
                                    elseif string.find(child.Text, CONFIG.EP8_Name) or string.find(child.Text, "Toxic") then 
                                        currentType = "EP8" 
                                    elseif string.find(child.Text, CONFIG.EP9_Name) or string.find(child.Text, "Maze") then 
                                        currentType = "EP9" 
                                    end
                                end
                            end
                        end
                    end
                    
                    if currentType ~= "" then
                        local availText = string.lower(v.Text)
                        
                        local avail = string.match(availText, "(%d+)%s+available")
                        if not avail then
                            avail = string.match(availText, "left:%s*(%d+)")
                        end
                        
                        local limit = string.match(availText, "limit:%s*(%d+)")
                        
                        local owned = string.match(availText, "(%d+)%s+owned")
                        if not owned then
                            owned = string.match(availText, "owned:%s*(%d+)")
                        end
                        
                        local isComplete = false
                        
                        if avail then
                            if tonumber(avail) <= 0 then 
                                isComplete = true 
                            end
                        elseif owned and limit then
                            if tonumber(limit) > 0 and tonumber(owned) >= tonumber(limit) then 
                                isComplete = true 
                            end
                        end

                        if isComplete then
                            if not STATE[currentType.."_Done"] then
                                STATE[currentType.."_Done"] = true
                                DLog("SCANNER", "✅ [COMPLETED]: " .. currentType .. " has reached its limit!")
                            end
                        end
                    end
                end
            end
        end
    end)
end

