-- =====================================================================
-- 🎒 7. MEMORY DATA SYSTEM & INVENTORY CACHE
-- =====================================================================

local PlayerDataCache = nil
local InventoryTableCache = nil

local cachedSeedsText = "0"
local cachedTicketsText = "0"
local cachedEggsText = "0"
local CurrentTicketInMem = 0
local InitialTicketValue = nil

local function UpdateInventoryCache()
    local gc = getgc(true)
    for i = 1, #gc do
        local obj = gc[i]
        if type(obj) == "table" then
            pcall(
                function()
                    for uid, data in pairs(obj) do
                        if type(uid) == "string" then
                            if string.find(uid, "unique_", 1, true) then
                                if data.ItemData then
                                    if data.ItemData.ID then
                                        InventoryTableCache = obj
                                    end
                                end
                            end
                        end
                    end
                end
            )
            if InventoryTableCache then break end
        end
    end
end

local function HasRafflesia()
    if not InventoryTableCache then
        UpdateInventoryCache()
    end
    
    if InventoryTableCache then
        for uid, data in pairs(InventoryTableCache) do
            if type(uid) == "string" then
                if string.find(uid, "unique_", 1, true) then
                    if data.ItemData then
                        if data.ItemData.ID then
                            if data.ItemData.ID == "unit_rafflesia" then
                                return true
                            end
                        end
                    end
                end
            end
        end
    end
    return false
end

local function UpdatePlayerDataCache()
    local gc = getgc(true)
    for i = 1, #gc do
        local obj = gc[i]
        if type(obj) == "table" then
            pcall(
                function()
                    if obj.Seeds and type(obj.Seeds) == "number" then
                        if obj.Tickets and type(obj.Tickets) == "number" then
                            PlayerDataCache = obj
                        end
                    end
                end
            )
            if PlayerDataCache then break end
        end
    end
end

local function UpdateCurrenciesFromMemory()
    pcall(
        function()
            if not PlayerDataCache then UpdatePlayerDataCache() end
            if PlayerDataCache then
                CurrentTicketInMem = PlayerDataCache.Tickets or 0
                cachedSeedsText = tostring(PlayerDataCache.Seeds or 0)
                cachedTicketsText = tostring(CurrentTicketInMem)
                cachedEggsText = tostring(PlayerDataCache.EasterEggs or 0)
            end
        end
    )
end

-- =====================================================================
-- 🔄 8. ABSOLUTE SMALLEST SERVER HOP FUNCTIONS
-- =====================================================================

local function FetchServerList(placeId, cursor)
    local url = "https://games.roblox.com/v1/games/" .. tostring(placeId) .. "/servers/Public?sortOrder=Desc&limit=" .. tostring(HopConfig.ApiLimit)
    
    if cursor and cursor ~= "" then
        url = url .. "&cursor=" .. tostring(cursor)
    end

    local success, response = pcall(function()
        return request({
            Url = url,
            Method = "GET"
        })
    end)

    if success and response and response.Body then
        local decodeSuccess, decoded = pcall(function() return HttpService:JSONDecode(response.Body) end)
        if decodeSuccess then return decoded end
    end
    return nil
end

local function FindAbsoluteSmallestServer()
    local bestJobId = nil
    local lowestCountFound = math.huge
    local currentCursor = ""
    local pagesCompleted = 0
    local targetMaxPlayersForHop = HopConfig.PlayersToTriggerHop - 2
    
    DebugPrint("เริ่มค้นหาห้องที่ว่างที่สุด (ลิมิตสูงสุดห้องใหม่: " .. tostring(targetMaxPlayersForHop) .. " คน)...")

    while pagesCompleted < HopConfig.MaxPagesToScan do
        pagesCompleted = pagesCompleted + 1
        local data = FetchServerList(HopConfig.TargetPlaceId, currentCursor)
        
        if data and data.data then
            for _, server in ipairs(data.data) do
                if server.id ~= game.JobId and server.playing < server.maxPlayers then
                    if server.playing < lowestCountFound then
                        lowestCountFound = server.playing
                        bestJobId = server.id
                        if lowestCountFound <= 2 then return bestJobId, lowestCountFound end
                    end
                end
            end
            if data.nextPageCursor and data.nextPageCursor ~= "" then
                currentCursor = data.nextPageCursor
            else
                break
            end
        else
            break
        end
        task.wait(0.05)
    end
    return bestJobId, lowestCountFound
end

local function ExecuteDeepHop()
    local targetId, finalCount = FindAbsoluteSmallestServer()
    local targetMaxPlayersForHop = HopConfig.PlayersToTriggerHop - 2

    if targetId then
        if finalCount <= targetMaxPlayersForHop then
            DebugPrint("พบห้องเป้าหมาย (" .. tostring(finalCount) .. " คน) กำลังวาป...")
            pcall(function()
                TeleportService:TeleportToPlaceInstance(HopConfig.TargetPlaceId, targetId, LocalPlayer)
            end)
            return true
        else
            DebugPrint("ห้องที่เจอมี " .. tostring(finalCount) .. " คน ซึ่งเกินเกณฑ์ จะไม่ทำการวาป")
            return false
        end
    end
    return false
end

