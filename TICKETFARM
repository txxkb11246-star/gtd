task.spawn(function()
    DebugPrint("5. เริ่มระบบเก็บไข่ (Egg Collector)...")
    
    local RemoteEvents = ReplicatedStorage:WaitForChild("RemoteEvents")
    local CollectRemote = RemoteEvents:WaitForChild("CollectCollectable")
    
    local function TryCollect(obj)
        local id = obj:GetAttribute("ID")
        if id then
            if type(id) == "number" then
                pcall(function() 
                    CollectRemote:FireServer(id) 
                end)
                return true
            end
        end
        return false
    end

    -- 🌟 ระบบที่ 1: ดักจับไข่เกิดใหม่ (Event Listener)
    Workspace.DescendantAdded:Connect(function(obj)
        if TryCollect(obj) then 
            return 
        end
        
        local conn
        conn = obj:GetAttributeChangedSignal("ID"):Connect(function()
            TryCollect(obj)
            if conn then 
                conn:Disconnect() 
            end
        end)
        
        task.delay(2, function()
            if conn then 
                conn:Disconnect() 
            end
        end)
    end)

    -- 🌟 ระบบที่ 2: วนลูปกวาดไข่ที่ค้างอยู่ในแมพทั้งหมด (Sweeper Loop)
    while true do
        local descendants = Workspace:GetDescendants()
        
        for i = 1, #descendants do
            local v = descendants[i]
            local id = v:GetAttribute("ID")
            
            if id then 
                pcall(function() 
                    CollectRemote:FireServer(id) 
                end) 
            end
        end
        
        task.wait(3) 
    end
end)

