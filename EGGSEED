-- 🔍 MASTER FUNCTION: ระบบสแกนไข่ขั้นเทพ (Dumper Scan)
-- =====================================================================
local function RefreshAndCheckUI()
    
    pcall(
        function()
            
            local leftPanel = GameGui.Screen:WaitForChild("Left")
            local sidebar = leftPanel:WaitForChild("Sidebar")
            local items = sidebar:WaitForChild("Items")
            local collectables = items:WaitForChild("Collectables")
            local itemsInner = collectables:WaitForChild("Items")
            local SidebarBtn = itemsInner:WaitForChild("Button")
            
            if SidebarBtn then
                
                local connections = getconnections(SidebarBtn.MouseButton1Click)
                local btnIndex = 1
                
                while btnIndex <= #connections do
                    
                    local c = connections[btnIndex]
                    c:Fire()
                    btnIndex = btnIndex + 1
                    
                end
                
            end
            
            local RightPanel = MainCollectUI:WaitForChild("Right", 3)
            
            if RightPanel then
                
                local EasterTab = RightPanel:WaitForChild("easter26", 3)
                
                if EasterTab then
                    
                    local consTab = getconnections(EasterTab.MouseButton1Click)
                    local tabIndex = 1
                    
                    while tabIndex <= #consTab do
                        
                        local c = consTab[tabIndex]
                        c:Fire()
                        tabIndex = tabIndex + 1
                        
                    end
                    
                end
                
            end
            
            task.wait(1.5)
            
            local descendants = GameGui:GetDescendants()
            local scanIndex = 1
            
            while scanIndex <= #descendants do
                
                local v = descendants[scanIndex]
                
                if v:IsA("TextLabel") then
                    
                    local textLower = string.lower(v.Text)
                    
                    local foundOwned = string.find(textLower, "owned", 1, true)
                    local foundLimit = string.find(textLower, "limit", 1, true)
                    local foundLeft = string.find(textLower, "left", 1, true)
                    local foundFullText = string.find(textLower, "full", 1, true)
                    
                    if foundOwned or foundLimit or foundLeft or foundFullText then
                        
                        local eggName = "Unknown Egg"
                        local parentGroup = v.Parent
                        
                        if parentGroup then
                            
                            local grandParent = parentGroup.Parent
                            
                            if grandParent then
                                
                                local gpDescendants = grandParent:GetDescendants()
                                local gpIndex = 1
                                local FoundName = false
                                
                                while gpIndex <= #gpDescendants do
                                    
                                    if FoundName == true then
                                        
                                        break
                                        
                                    end
                                    
                                    local child = gpDescendants[gpIndex]
                                    
                                    if child:IsA("TextLabel") then
                                        
                                        if child ~= v then
                                            
                                            local childTextLower = string.lower(child.Text)
                                            local foundEggWord = string.find(childTextLower, "egg", 1, true)
                                            
                                            if foundEggWord then
                                                
                                                eggName = child.Text
                                                FoundName = true
                                                
                                            else
                                                
                                                local lenCheck = string.len(child.Text)
                                                local checkOwned = string.find(childTextLower, "owned", 1, true)
                                                
                                                if lenCheck > 10 then
                                                    
                                                    if not checkOwned then
                                                        
                                                        eggName = child.Text
                                                        FoundName = true
                                                        
                                                    end
                                                    
                                                end
                                                
                                            end
                                            
                                        end
                                        
                                    end
                                    
                                    gpIndex = gpIndex + 1
                                    
                                end
                                
                            end
                            
                        end
                        
                        eggName = string.gsub(eggName, "\n", " ")
                        
                        local isTargetEgg = string.find(string.lower(eggName), string.lower(CONFIG.TargetEgg_Name), 1, true)
                        
                        if isTargetEgg then
                            
                            local availText = string.lower(v.Text)
                            
                            local avail = string.match(availText, "(%d+)%s+available")
                            
                            if not avail then
                                
                                avail = string.match(availText, "left:%s*(%d+)")
                                
                            end
                            
                            local limit = string.match(availText, "limit:%s*(%d+)")
                            
                            local owned = string.match(availText, "(%d+)%s+owned")
                            
                            if not owned then
                                
                                owned = string.match(availText, "owned:%s*(%d+)")
                                
                            end
                            
                            local numOwned = tonumber(owned)
                            
                            if not numOwned then
                                
                                numOwned = 0
                                
                            end
                            
                            local numLimit = tonumber(limit)
                            
                            if not numLimit then
                                
                                numLimit = 0
                                
                            end
                            
                            local numLeft = 999
                            local isComplete = false
                            
                            local checkFull = string.find(availText, "full", 1, true)
                            local checkOneOne = string.find(availText, "1/1", 1, true)
                            
                            if checkFull or checkOneOne then
                                
                                isComplete = true
                                numLeft = 0
                                
                            else
                                
                                if avail then
                                    
                                    numLeft = tonumber(avail)
                                    
                                    if numLeft <= 0 then
                                        
                                        isComplete = true
                                        
                                    end
                                    
                                else
                                    
                                    if numLimit > 0 then
                                        
                                        numLeft = numLimit - numOwned
                                        
                                        if numLeft <= 0 then
                                            
                                            isComplete = true
                                            
                                        end
                                        
                                    end
                                    
                                end
                                
                            end
                            
                            if numLeft < 0 then
                                
                                numLeft = 0
                                
                            end
                            
                            if isComplete == true then
                                
                                if STATE.TargetEgg_Done == false then
                                    
                                    STATE.TargetEgg_Done = true
                                    
                                    if CONFIG.DEBUG_MODE == true then
                                        
                                        print("[SCANNER] ✅ สำเร็จ! ได้รับไข่เป้าหมายเรียบร้อยแล้ว: " .. eggName)
                                        
                                    end
                                    
                                end
                                
                            end
                            
                        end
                        
                    end
                    
                end
                
                scanIndex = scanIndex + 1
                
            end
            
        end
    )
    
end

