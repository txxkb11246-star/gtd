-- 🚨 ดักรอจนกว่าเกมจะโหลด UI ตัวเลขเสร็จ (ห้ามส่งค่า 0)
local function EnsureCurrenciesLoaded()
    
    local LoadingComplete = false
    local TimeoutCounter = 15 -- ปรับลดเหลือ 15 วิ เผื่อในกรณีที่เพิ่งเริ่มเล่นแล้วเงินเป็น 0 จริงๆ จะได้ไม่ค้าง
    
    while LoadingComplete == false do
        
        UpdateCurrenciesText()
        
        local SeedIsGood = false
        local EggIsGood = false
        
        if cachedSeedsText ~= nil then
            
            if cachedSeedsText ~= "0" then
                
                if cachedSeedsText ~= "" then
                    
                    SeedIsGood = true
                    
                end
                
            end
            
        end
        
        if cachedEggsText ~= nil then
            
            if cachedEggsText ~= "0" then
                
                if cachedEggsText ~= "" then
                    
                    EggIsGood = true
                    
                end
                
            end
            
        end
        
        if SeedIsGood == true then
            
            if EggIsGood == true then
                
                LoadingComplete = true
                
            end
            
        end
        
        if TimeoutCounter <= 0 then
            
            LoadingComplete = true
            
        end
        
        if LoadingComplete == false then
            
            task.wait(1)
            TimeoutCounter = TimeoutCounter - 1
            
        end
        
    end
    
end

