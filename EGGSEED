local LAST_HORST_MSG = ""

local function ForceUpdateHorst()
    
    pcall(
        function()
            
            if _G.Horst_SetDescription then
                
                local HasRaff = false
                
                pcall(
                    function()
                        
                        if HasRafflesia then
                            
                            HasRaff = HasRafflesia()
                            
                        end
                        
                    end
                )
                
                local RaffString = "False"
                
                if HasRaff == true then
                    
                    RaffString = "True"
                    
                end
                
                local SafeSeedText = "0"
                
                if cachedSeedsText ~= nil then
                    
                    SafeSeedText = cachedSeedsText
                    
                end
                
                local SafeEggText = "0"
                
                if cachedEggsText ~= nil then
                    
                    SafeEggText = cachedEggsText
                    
                end
                
                local BaseStats = string.format("🌱 %s , 🥚 %s , 🌸 Raff: %s", SafeSeedText, SafeEggText, RaffString)
                local FinalDescription = BaseStats .. STATE.SniperQuest_String .. STATE.BoxQuest_String
                
                local JsonData = {
                    
                    Quest = FinalDescription
                    
                }
                
                local EncodedJson = HttpService:JSONEncode(JsonData)
                
                if FinalDescription ~= LAST_HORST_MSG then
                    
                    LAST_HORST_MSG = FinalDescription
                    
                    _G.Horst_SetDescription(FinalDescription, EncodedJson)
                    
                end
                
            end
            
        end
    )
    
end

