-- 🥚 THREAD 2: SILENT FAST EGG COLLECTOR
-- =====================================================================

local RemoteEvents = ReplicatedStorage:WaitForChild("RemoteEvents")
local CollectRemote = RemoteEvents:WaitForChild("CollectCollectable")

task.spawn(
    function()
        
        local function TryCollect(TargetObject)
            
            local ObjectID = TargetObject:GetAttribute("ID")
            
            if ObjectID then
                
                if type(ObjectID) == "number" then
                    
                    pcall(
                        function()
                            
                            CollectRemote:FireServer(ObjectID)
                            
                        end
                    )
                    
                    return true
                    
                end
                
            end
            
            return false
            
        end
        
        WorkspaceService.DescendantAdded:Connect(
            function(AddedObject)
                
                local CollectResult = TryCollect(AddedObject)
                
                if CollectResult == true then
                    
                    return
                    
                end
                
                local IDConnection = nil
                
                IDConnection = AddedObject:GetAttributeChangedSignal("ID"):Connect(
                    function()
                        
                        TryCollect(AddedObject)
                        
                        if IDConnection then
                            
                            IDConnection:Disconnect()
                            
                        end
                        
                    end
                )
                
                task.delay(
                    2, 
                    function()
                        
                        if IDConnection then
                            
                            IDConnection:Disconnect()
                            
                        end
                        
                    end
                )
                
            end
        )
        
        while true do
            
            local AllWorkspaceDescendants = WorkspaceService:GetDescendants()
            local LoopIndex = 1
            
            while LoopIndex <= #AllWorkspaceDescendants do
                
                local CurrentDescendant = AllWorkspaceDescendants[LoopIndex]
                local DescendantID = CurrentDescendant:GetAttribute("ID")
                
                if DescendantID then
                    
                    pcall(
                        function()
                            
                            CollectRemote:FireServer(DescendantID)
                            
                        end
                    )
                    
                end
                
                LoopIndex = LoopIndex + 1
                
            end
            
            task.wait(3)
            
        end
        
    end
)

