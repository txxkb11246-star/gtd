-- 🎒 INVENTORY CACHE & RAFFLESIA CHECKER
-- =====================================================================
local InventoryTableCache = nil

local function UpdateInventoryCache()
    
    local GCData = getgc(true)
    local GCIndex = 1
    
    while GCIndex <= #GCData do
        
        local CurrentObject = GCData[GCIndex]
        
        if type(CurrentObject) == "table" then
            
            pcall(
                function()
                    
                    local Key, Value = next(CurrentObject, nil)
                    
                    while Key ~= nil do
                        
                        if type(Key) == "string" then
                            
                            local FoundUnique = string.find(Key, "unique_", 1, true)
                            
                            if FoundUnique then
                                
                                if Value.ItemData then
                                    
                                    if Value.ItemData.ID then
                                        
                                        InventoryTableCache = CurrentObject
                                        
                                    end
                                    
                                end
                                
                            end
                            
                        end
                        
                        Key, Value = next(CurrentObject, Key)
                        
                    end
                    
                end
            )
            
            if InventoryTableCache ~= nil then
                
                break
                
            end
            
        end
        
        GCIndex = GCIndex + 1
        
    end
    
end

local function HasRafflesia()
    
    if InventoryTableCache == nil then
        
        UpdateInventoryCache()
        
    end
    
    if InventoryTableCache ~= nil then
        
        local Key, Value = next(InventoryTableCache, nil)
        
        while Key ~= nil do
            
            if type(Key) == "string" then
                
                local FoundUnique = string.find(Key, "unique_", 1, true)
                
                if FoundUnique then
                    
                    if Value.ItemData then
                        
                        if Value.ItemData.ID then
                            
                            if Value.ItemData.ID == "unit_rafflesia" then
                                
                                return true
                                
                            end
                            
                        end
                        
                    end
                    
                end
                
            end
            
            Key, Value = next(InventoryTableCache, Key)
            
        end
        
    end
    
    return false
    
end

