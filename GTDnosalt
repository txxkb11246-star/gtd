local function GetTrueOwnedInventory()
    local hasRaff = false
    local hasLawn = false

    local function checkStr(txt)
        if not txt then return end
        txt = string.lower(txt)
        if string.find(txt, "raff") then hasRaff = true end
        if string.find(txt, "lawn") then hasLawn = true end
    end

    pcall(function()
        for _, v in pairs(LP.Backpack:GetChildren()) do checkStr(v.Name) end
        if LP.Character then
            for _, v in pairs(LP.Character:GetChildren()) do checkStr(v.Name) end
