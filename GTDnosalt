        local val = 0
        pcall(function() 
            local cashText = "0"
            pcall(function()
                cashText = LP.PlayerGui.GameGui.Screen.Bottom.CurrencyDisplay.Cash.Text
            end)
            val = tonumber((tostring(cashText):gsub(",", ""):match("%d+"))) or 0
