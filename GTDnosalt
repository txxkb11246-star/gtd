local function SafeNum(input)
    if type(input) == "number" then return math.floor(input) end
    local s = tostring(input):upper():gsub(",", "")
    local nStr = s:match("[%d%.]+")
    local val = tonumber(nStr) or 0
    if s:find("K") then val = val * 1000 elseif s:find("M") then val = val * 1000000 end
    return math.floor(val)
end

local function GetTrueOwnedInventory()
    local hasRaff = false
    local hasLawn = false

    local function scan(parent)
        if not parent then return end
        for _, v in pairs(parent:GetChildren()) do
            local n = string.lower(v.Name)
            if string.find(n, "rafflesia") then hasRaff = true end
            if string.find(n, "lawnmower") then hasLawn = true end
        end
    end

    scan(LP.Backpack)
    if LP.Character then scan(LP.Character) end

    pcall(function()
        local mainUI = LP.PlayerGui.GameGui.Screen
        local scroll = mainUI.Middle.Inventory.Inventory.Frame.Items.Items.ScrollingFrame
        for _, v in pairs(scroll:GetDescendants()) do
            local n = string.lower(v.Name)
            if n == "unit_rafflesia" or string.find(n, "rafflesia") then hasRaff = true end
            if n == "unit_lawnmower" or string.find(n, "lawnmower") then hasLawn = true end
        end
    end)

    return hasRaff, hasLawn
end

-- 🧠 AI ตัดสินใจเส้นทาง (อัปเดตแก้ AutoSeed ไป BGarden)
local function GetRoutingPlan()
    local hasRaff, hasLawn = GetTrueOwnedInventory()
    local targetMapName = "map_farm"
    local farmUnit = "Tomato"
    local shouldRollGacha = false

    if CONFIG.SelectMap == "AutoSeed" then
        if hasRaff then
            targetMapName = "map_christmas"; farmUnit = "Rafflesia"; shouldRollGacha = false
        elseif hasLawn then
            -- 🎯 แก้ตรงนี้: ถ้าเอา Seed และมี Lawn ให้ไป BGarden ชัวร์ 100%
            targetMapName = "map_back_garden"; farmUnit = "Lawnmower"; shouldRollGacha = true 
        else
            targetMapName = "map_farm"; farmUnit = "Tomato"; shouldRollGacha = true
        end
    elseif CONFIG.SelectMap == "AutoGem" then
        if hasLawn then
            -- 💎 ถ้าเอา Gem และมี Lawn ให้ไป Space
            targetMapName = "map_space"; farmUnit = "Lawnmower"; shouldRollGacha = false 
        else
            targetMapName = "map_farm"; farmUnit = "Tomato"; shouldRollGacha = true
        end
    elseif CONFIG.SelectMap == "Ice" then
        targetMapName = "map_christmas"
        if hasRaff then farmUnit = "Rafflesia" elseif hasLawn then farmUnit = "Lawnmower" else farmUnit = "Tomato" end
        shouldRollGacha = not hasRaff
    elseif CONFIG.SelectMap == "Space" then
        targetMapName = "map_space"
        if hasLawn then farmUnit = "Lawnmower" else farmUnit = "Tomato" end
        shouldRollGacha = not hasLawn
    elseif CONFIG.SelectMap == "BGarden" then
        targetMapName = "map_back_garden"
        if hasLawn then farmUnit = "Lawnmower" else farmUnit = "Tomato" end
        shouldRollGacha = not hasLawn
    end

    return targetMapName, farmUnit, shouldRollGacha
end

-- 🚀 ฟังก์ชันเช็คเงินอัจฉริยะ (ถ้าเงินถึงเป้า เตะกลับ Lobby ไปสุ่มทันที)
local function CheckAndGoLobbyIfRich()
    local _, _, shouldRoll = GetRoutingPlan()
    if not shouldRoll then return false end

    local seedsText = "0"
    pcall(function() seedsText = LP.PlayerGui.GameGui.Screen.Bottom.CurrencyDisplay.SeedsDisplay.Title.Text end)
    local seedsAmount = SafeNum(seedsText)
    
    if seedsAmount >= 8500 then
        DebugLog("💰 [SEED CHECK] เงินครบ " .. tostring(seedsAmount) .. " บังคับกลับ Lobby ไปสุ่มตัว!")
        pcall(function() 
            local rf = ReplicatedStorage:FindFirstChild("RemoteFunctions")
            if rf then
                if rf:FindFirstChild("ReturnToLobby") then rf.ReturnToLobby:InvokeServer() end
                if rf:FindFirstChild("LeaveGame") then rf.LeaveGame:InvokeServer() end
            end
        end)
        task.wait(1.5)
        pcall(function() game:GetService("TeleportService"):Teleport(game.PlaceId, LP) end)
        task.wait(9e9) -- หยุดการทำงานรอโหลดหน้า
        return true
    end
    return false
end

