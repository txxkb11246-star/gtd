            if not safeWait(6)  then return end; deployLawnmower(1, DATA.LAW4)
            if not safeWait(13) then return end; deployLawnmower(1, DATA.LAW5)
            if not safeWait(4)  then return end; deployLawnmower(3, DATA.LAW6)
            if not safeWait(2)  then return end; deployLawnmower(3, DATA.LAW7)
            if not safeWait(1.5) then return end; deployLawnmower(1, DATA.LAW8)
            if not safeWait(1.5) then return end; deployLawnmower(1, DATA.LAW9)
        end
        while not isEnd.value do task.wait(1) end
    end

    while true do
        runSession()
        task.wait(3)
        if not CheckAndGoLobbyIfRich() then
            -- 🛡️ ระบบกันค้าง
            for i = 1, 5 do
                pcall(function() rf.RestartGame:InvokeServer() end)
                task.wait(1.5)
            end
        end
        task.wait(3)
    end
end

