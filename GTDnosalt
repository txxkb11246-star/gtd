local function GetTrueOwnedInventory()
    local hasRaff = false
    local hasLawn = false

    local function checkStr(txt)
        if not txt then return end
        txt = string.lower(txt)
        if string.find(txt, "raff") then 
            hasRaff = true 
        end
        if string.find(txt, "lawn") then 
            hasLawn = true 
        end
    end

    pcall(function()
        for _, v in pairs(LP.Backpack:GetChildren()) do 
            checkStr(v.Name) 
        end
        if LP.Character then 
            for _, v in pairs(LP.Character:GetChildren()) do 
                checkStr(v.Name) 
            end 
        end
    end)

    pcall(function()
        local bUI = LP.PlayerGui:FindFirstChild("BackpackGui")
        if bUI and bUI:FindFirstChild("Backpack") and bUI.Backpack:FindFirstChild("Hotbar") then
            for i = 1, 5 do
                local slot = bUI.Backpack.Hotbar:FindFirstChild(tostring(i))
                if slot and slot:FindFirstChild("ToolName") then 
                    checkStr(slot.ToolName.Text) 
                end
            end
        end
    end)

    pcall(function()
        local mainUI = LP.PlayerGui:FindFirstChild("GameGui")
        if mainUI and mainUI:FindFirstChild("Screen") then
            local middle = mainUI.Screen:FindFirstChild("Middle")
            if middle and middle:FindFirstChild("Inventory") then
                local scroll = middle.Inventory.Inventory.Frame.Items.Items.ScrollingFrame
                for _, v in pairs(scroll:GetDescendants()) do
                    checkStr(v.Name)
                    if v:IsA("TextLabel") or v:IsA("TextButton") then 
                        checkStr(v.Text) 
                    end
                end
            end
        end
    end)

    return hasRaff, hasLawn
end

