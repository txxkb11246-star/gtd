local function ClickButton(guiObj)
    if not guiObj then return end
    local pos = guiObj.AbsolutePosition
    local size = guiObj.AbsoluteSize
    local insetY = GuiService:GetGuiInset().Y
    local cX = pos.X + (size.X / 2)
    local cY = pos.Y + (size.Y / 2) + insetY
    
    VirtualInputManager:SendMouseMoveEvent(cX, cY, game)
    task.wait(0.1)
    VirtualInputManager:SendMouseButtonEvent(cX, cY, 0, true, game, 1)
    task.wait(0.1)
    VirtualInputManager:SendMouseButtonEvent(cX, cY, 0, false, game, 1)
end

local function EnsureHotbarSpace(reqStr)
    local bUI = LP.PlayerGui:FindFirstChild("BackpackGui")
    if not bUI then return end
    
    local backpack = bUI:FindFirstChild("Backpack")
    if not backpack then return end
    
    local hotbar = backpack:FindFirstChild("Hotbar")
    if not hotbar then return end
    
    local count = 0
    local unneededName = nil
    
    for i = 1, 5 do
        local slot = hotbar:FindFirstChild(tostring(i))
        if slot then
            local toolName = slot:FindFirstChild("ToolName")
            if toolName and toolName.Text ~= "" then
                count = count + 1
                if not string.find(string.lower(toolName.Text), string.lower(reqStr)) then 
                    unneededName = toolName.Text 
                end
            end
        end
    end
    
    if count >= 5 and unneededName then
        pcall(function()
            local main = LP.PlayerGui.GameGui.Screen
            if main.Middle.Inventory.Visible == false then 
                ClickButton(main.Left.Sidebar.Items.Inventory.Items.Button)
                task.wait(2) 
            end
            
            local scroll = main.Middle.Inventory.Inventory.Frame.Items.Items.ScrollingFrame
            for _, v in pairs(scroll:GetDescendants()) do
                if v:IsA("TextLabel") and string.find(string.lower(v.Text), string.lower(unneededName)) then
                    local targetBtn = v
                    if v:IsA("GuiButton") then
                        targetBtn = v
                    else
                        local ancestor = v:FindFirstAncestorWhichIsA("GuiButton")
                        if ancestor then
                            targetBtn = ancestor
                        end
                    end
                    ClickButton(targetBtn)
                    task.wait(1.5)
                    break
                end
            end
        end)
    end
end

local function IsInHotbar(unitName)
    local bUI = LP.PlayerGui:FindFirstChild("BackpackGui")
    if not bUI then return false end
    
    local backpack = bUI:FindFirstChild("Backpack")
    if not backpack then return false end
    
    local hb = backpack:FindFirstChild("Hotbar")
    if not hb then return false end
    
    local key = string.lower(unitName)
    for i = 1, 5 do
        local slot = hb:FindFirstChild(tostring(i))
        if slot then
            local toolName = slot:FindFirstChild("ToolName")
            if toolName and string.find(string.lower(toolName.Text), key) then 
                return true 
            end
        end
    end
    return false
end

local function TripleLayerEquip(shortName, fullName)
    if IsInHotbar(shortName) then 
        return true 
    end
    
    EnsureHotbarSpace(shortName)
    
    pcall(function()
        local rf = ReplicatedStorage:WaitForChild("RemoteFunctions", 3)
        if rf then
            local setUnitEquipped = rf:FindFirstChild("SetUnitEquipped")
            if setUnitEquipped then
                if shortName == "Tomato" then 
                    setUnitEquipped:InvokeServer("unique_1", true)
                elseif shortName == "Lawnmower" then 
                    setUnitEquipped:InvokeServer("unit_lawnmower", true)
                elseif shortName == "Rafflesia" then 
                    setUnitEquipped:InvokeServer("unit_rafflesia", true) 
                end
            end
        end
    end)
    
    task.wait(1.5)
    if IsInHotbar(shortName) then 
        return true 
    end
    
    pcall(function()
        local main = LP.PlayerGui.GameGui.Screen
        if main.Middle.Inventory.Visible == false then 
            ClickButton(main.Left.Sidebar.Items.Inventory.Items.Button)
            task.wait(3) 
        end
        
        local targetBtn = nil
        local searchName = string.lower(fullName)
        if shortName == "Tomato" then
            searchName = "unique_1"
        end
        
        local scroll = main.Middle.Inventory.Inventory.Frame.Items.Items.ScrollingFrame
        for _, v in pairs(scroll:GetDescendants()) do
            if string.lower(v.Name) == searchName or string.find(string.lower(v.Name), string.lower(shortName)) then 
                targetBtn = v
                break 
            end
        end
        
        if targetBtn then 
            for i = 1, 5 do 
                ClickButton(targetBtn)
                task.wait(1.5)
                if IsInHotbar(shortName) then 
                    break 
                end 
            end 
        end
    end)
    
    return IsInHotbar(shortName)
end

