-- [10] LOBBY & AGGRESSIVE GACHA ENGINE
-- ==========================================
local function StartLobbyMasterEngine()
    local rf = ReplicatedStorage:WaitForChild("RemoteFunctions")
    
    while Workspace:FindFirstChild("Map") and Workspace.Map:FindFirstChild("Garden") do
        pcall(function()
            local mainUI = LP.PlayerGui:WaitForChild("GameGui", 10).Screen
            if mainUI.Middle.Inventory.Visible == false then 
                local invBtn = mainUI.Left.Sidebar.Items.Inventory.Items.Button
                ClickButton(invBtn); task.wait(2)
            end

            local seedsText = "0"
            pcall(function() seedsText = mainUI.Bottom.CurrencyDisplay.SeedsDisplay.Title.Text end)
            local seedsAmount = SafeNum(seedsText)
            
            -- โหลดแผนจาก AI (Auto Routing)
            local targetMapName, plan, shouldRoll = GetRoutingPlan()
            
            if not IsInHotbar(plan) then
                DebugLog("🔄 [LOBBY] ถือตัวผิด! ต้องสวมใส่: " .. plan)
                if plan == "Rafflesia" then TripleLayerEquip("Rafflesia", "unit_rafflesia")
                elseif plan == "Lawnmower" then TripleLayerEquip("Lawnmower", "unit_lawnmower")
                else TripleLayerEquip("Tomato", "unique_1") end
                
                task.wait(1.5)
                if not IsInHotbar(plan) then
                    DebugLog("❌ [LOBBY] ใส่ตัว " .. plan .. " ไม่สำเร็จ! วนลูปพยายามใส่ใหม่...")
                    task.wait(2); return 
                end
            end

            if shouldRoll and seedsAmount >= 8500 then
                DebugLog("🎰 [LOBBY] เงินมี " .. tostring(seedsAmount) .. " (เป้า 8500) กำลังสุ่มกล่อง Tropical 10 กล่อง...")
                rf.BuyUnitBox:InvokeServer("ub_tropical", 10)
                task.wait(8) 
            else
                local pads = {85.05, 97.05, 109.05, 121.05}
                local pID = math.random(5, 8)
                
                if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                    DebugLog("🚶 [LOBBY] สวมใส่เป๊ะแล้ว กำลังเดินไปวาร์ปที่ " .. targetMapName)
                    LP.Character.HumanoidRootPart.CFrame = CFrame.new(pads[pID - 4], 71.7, 788.8)
                    task.wait(4.5)
                    rf["LobbySetMap_" .. pID]:InvokeServer(targetMapName)
                    task.wait(1.5)
                    for i = 3, 1, -1 do rf["LobbySetMaxPlayers_" .. pID]:InvokeServer(i); task.wait(0.7) end
                    task.wait(10)
                end
            end
        end)
        task.wait(1)
    end
    
    -- โหลดแผนจาก AI เพื่อรันฟังก์ชันฟาร์มที่ถูกต้อง
    local _, farmUnit, _ = GetRoutingPlan()
    
    if farmUnit == "Rafflesia" then RunIceFarmMaster()
    elseif farmUnit == "Lawnmower" then 
        if CONFIG.SelectMap == "BGarden" or CONFIG.SelectMap == "AutoSeed" then 
            RunBGardenFarmMaster() 
        else 
            RunSpaceFarmMaster() 
        end
    else RunTomatoFarmMaster() end
end

local function isInLobby()
    local map = Workspace:FindFirstChild("Map")
    if not map then return false end
    return map:FindFirstChild("Garden") ~= nil
end

