local function GetExactSeeds()
    local val = 0
    pcall(function()
        local seedText = "0"
        pcall(function() 
            seedText = LP.PlayerGui.GameGui.Screen.Bottom.CurrencyDisplay.SeedsDisplay.Title.Text 
        end)
