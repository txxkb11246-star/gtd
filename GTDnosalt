local function GetRoutingPlan()
    local hasRaff, hasLawn = GetTrueOwnedInventory()
    local targetMapName = "map_farm"
    local farmUnit = "Tomato"
    local shouldRollGacha = false
    local targetBoxKey = "confusion" 

    if CONFIG.SelectMap == "AutoSeed" then
        if hasRaff then
            -- 🌸 มี Rafflesia: ไปด่าน Ice (map_christmas) เสมอ (ไม่สนว่าจะมี Lawn หรือไม่)
            DebugLog("🗺️ [LOGIC] AutoSeed: พบ Rafflesia -> มุ่งหน้าด่าน Ice")
            targetMapName = "map_christmas"
            farmUnit = "Rafflesia"
            shouldRollGacha = not hasLawn -- ถ้ายังไม่มี Lawn ให้สุ่มหา Lawn
            targetBoxKey = "find_lawn"
        elseif hasLawn then
            -- 🚜 ไม่มี Raff แต่มี Lawnmower: ไปด่าน BGarden
            DebugLog("🗺️ [LOGIC] AutoSeed: พบ Lawnmower (ไม่มี Raff) -> มุ่งหน้าด่าน BGarden")
            targetMapName = "map_back_garden"
            farmUnit = "Lawnmower"
            shouldRollGacha = true 
            targetBoxKey = "confusion" -- สุ่มหา Raff
        else
            -- 🍅 ไม่มีทั้งคู่: ไปด่าน Farm 
            DebugLog("🗺️ [LOGIC] AutoSeed: ไม่มีตัวแบก -> มุ่งหน้าด่าน Farm")
            targetMapName = "map_farm"
            farmUnit = "Tomato"
            shouldRollGacha = true
            targetBoxKey = "confusion" 
        end

    elseif CONFIG.SelectMap == "AutoGem" then
        if hasLawn then
            targetMapName = "map_space"
            farmUnit = "Lawnmower"
            shouldRollGacha = false 
        else
            targetMapName = "map_farm"
            farmUnit = "Tomato"
            shouldRollGacha = true
            targetBoxKey = "find_lawn"
        end

    elseif CONFIG.SelectMap == "Ice" then
        targetMapName = "map_christmas"
        if hasRaff then farmUnit = "Rafflesia" elseif hasLawn then farmUnit = "Lawnmower" else farmUnit = "Tomato" end
        shouldRollGacha = not hasRaff
        targetBoxKey = "confusion"

    elseif CONFIG.SelectMap == "Space" then
        targetMapName = "map_space"
        if hasLawn then farmUnit = "Lawnmower" else farmUnit = "Tomato" end
        shouldRollGacha = not hasLawn
        targetBoxKey = "find_lawn"

    elseif CONFIG.SelectMap == "BGarden" then
        targetMapName = "map_back_garden"
        if hasLawn then farmUnit = "Lawnmower" else farmUnit = "Tomato" end
        shouldRollGacha = not hasLawn
        targetBoxKey = "find_lawn"
    end

    return targetMapName, farmUnit, shouldRollGacha, targetBoxKey
end

