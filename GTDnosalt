        for i = 1, 3 do
            if isEnd.value then return end
            local ok = pcall(function() return rf.PlaceUnit:InvokeServer("unit_lawnmower", {Valid=true, PathIndex=pathIndex, Position=finalPos, DistanceAlongPath=config.dist, CF=finalCF, Rotation=180}) end)
            if ok then break end; task.wait(1)
        end
    end

