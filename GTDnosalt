WaitForRealData() -- บังคับรอจนกว่า UI เงินจะนิ่งและมีไอเทมในกระเป๋า

if isInLobby() then 
    StartLobbyMasterEngine() 
else 
    local _, farmUnit, _, _ = GetRoutingPlan()
    DebugLog("🎮 [FARM] สแกนเสร็จสิ้น: ตัดสินใจใช้แผนฟาร์มโหมด " .. farmUnit)
    
    if farmUnit == "Rafflesia" then RunIceFarmMaster()
    elseif farmUnit == "Lawnmower" then 
        if CONFIG.SelectMap == "BGarden" or CONFIG.SelectMap == "AutoSeed" then 
            RunBGardenFarmMaster() 
        else 
            RunSpaceFarmMaster() 
        end
    else RunTomatoFarmMaster() end
end
