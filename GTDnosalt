        local ox = (math.random() * 2 - 1) * 1.5; local oz = (math.random() * 2 - 1) * 1.5
        return { "unit_rafflesia", {Valid = true, PathIndex = trapConfig.path, Position = Vector3.new(trapConfig.pos.X + ox, trapConfig.pos.Y, trapConfig.pos.Z + oz), DistanceAlongPath = trapConfig.dist, CF = trapConfig.cf + Vector3.new(ox, 0, oz), Rotation = 180} }
    end

    local function runSession()
        forceRestart = false
        if hpConnection then hpConnection:Disconnect(); hpConnection = nil end
        if sensorConnection then sensorConnection:Disconnect(); sensorConnection = nil end

        for _, trap in ipairs(TRAPS) do trap.preloaded = nil; trap.nextAttackTime = 0 end

        task.spawn(function()
            local map = Workspace:WaitForChild("Map", 60)
            if map and map:WaitForChild("BaseHP", 60) then
                hpConnection = map.BaseHP.Changed:Connect(function(val) 
                    local hp = tonumber(tostring(val):match("[-%d%.]+")) or 100
                    if hp <= 0 and not forceRestart then 
                        forceRestart = true; task.wait(3); pcall(function() RemoteFunctions.RestartGame:InvokeServer() end)
                    end 
                end)
            end
        end)
        
        StartAutoSkip({value = forceRestart})

        if not hasAppliedSettings then
            hasAppliedSettings = true
            task.spawn(function()
                pcall(function() RemoteFunctions:WaitForChild("ChangeSetting"):InvokeServer("st_graphics", 2) end)
                pcall(function() RemoteFunctions:WaitForChild("ChangeSetting"):InvokeServer("st_background_music_volume", 1) end)
                pcall(function() RemoteFunctions:WaitForChild("ChangeSetting"):InvokeServer("st_fx_volume", 1) end)
                pcall(function() RemoteFunctions:WaitForChild("ChangeTickSpeed"):InvokeServer(2) end)
            end)
        end

        task.wait(2)
        pcall(function() RemoteFunctions:WaitForChild("PlaceDifficultyVote"):InvokeServer("dif_apocalypse") end) 
        task.wait(6)

        local EntitiesFolder = Workspace:WaitForChild("Map", 60):WaitForChild("Entities", 60)
        
        sensorConnection = RunService.Heartbeat:Connect(function()
            if forceRestart then return end
            local ct = tick()
            
            for _, trap in ipairs(TRAPS) do
                local kZ = false; local wZ = false
                local trapForward = trap.cf.LookVector
                
                for _, ent in ipairs(EntitiesFolder:GetChildren()) do
                    if ent.Name ~= "unit_rafflesia" then
                        local entPos = ent:GetPivot().Position
                        local offset = (entPos - trap.pos)
                        local distSq = (offset.X * offset.X) + (offset.Z * offset.Z)
                        
                        if distSq <= WARN_RADIUS_SQ then
                            local dirToEnt = offset.Unit
                            local dot = trapForward:Dot(dirToEnt)
                            
                            if dot >= CONE_THRESHOLD then
                                if distSq <= TRAP_RADIUS_SQ then 
                                    kZ = true; break 
                                else 
                                    wZ = true 
                                end
                            end
                        end
                    end
                end
                
                if wZ and not trap.preloaded then trap.preloaded = reloadTrap(trap) end
                
                if kZ and ct >= trap.nextAttackTime then
                    if not trap.preloaded then trap.preloaded = reloadTrap(trap) end
                    local bullet = trap.preloaded
                    trap.preloaded = nil
                    trap.nextAttackTime = ct + COOLDOWN_TIME 
                    task.spawn(function() pcall(function() PlaceUnitRemote:InvokeServer(unpack(bullet)) end) end)
                end
            end
        end)

        DebugLog("✅ Ice Strategic Farm Active (4 Inner Sensors)")
        while not forceRestart do task.wait(1) end
    end

    while true do 
        runSession() 
        if not CheckAndGoLobbyIfRich() then
            pcall(function() RemoteFunctions.RestartGame:InvokeServer() end)
        end
        task.wait(2) 
    end
end

